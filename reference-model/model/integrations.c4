model {
  // --- Actors → Channels ---
  customer -> bank.business.channels.mobile_bank 'Mobile banking' {
    technology 'HTTPS'
  }
  customer -> bank.business.channels.internet_bank 'Web banking' {
    technology 'HTTPS'
  }
  operator -> bank.business.channels.internet_bank 'Back-office operations' {
    technology 'HTTPS'
  }

  // --- Channels → Platform ---
  bank.business.channels.mobile_bank -[sync]-> bank.tech.platform.api_gateway 'All API calls' {
    technology 'REST/JSON, mTLS'
  }
  bank.business.channels.internet_bank -[sync]-> bank.tech.platform.api_gateway 'All API calls' {
    technology 'REST/JSON, mTLS'
  }

  // --- Platform → Auth ---
  bank.tech.platform.api_gateway -[sync]-> bank.tech.platform.iam 'Token validation' {
    technology 'REST, OAuth2'
  }

  // --- Platform → Core ---
  bank.tech.platform.api_gateway -[sync]-> bank.business.products.core_banking 'Account operations' {
    technology 'REST/JSON'
  }
  bank.tech.platform.api_gateway -[sync]-> bank.business.payments.payment_hub 'Payment initiation' {
    technology 'REST/JSON'
  }

  // --- Core integrations ---
  bank.business.payments.payment_hub -[sync]-> bank.business.products.core_banking 'Debit/credit operations' {
    technology 'gRPC, Protobuf'
  }
  bank.business.payments.payment_hub -[async]-> bank.support.risk.aml 'AML screening requests' {
    technology 'Kafka, Avro'
  }
  bank.business.payments.payment_hub -[sync]-> bank.business.payments.card_processing 'Card transactions' {
    technology 'REST/JSON'
  }
  bank.business.payments.payment_hub -[async]-> bank.support.notifications.notification_center 'Payment notifications' {
    technology 'Kafka, Avro'
  }

  // --- External ---
  bank.business.payments.card_processing -[sync]-> visa 'Card authorization' {
    technology 'ISO 8583'
  }
  bank.business.payments.payment_hub -[sync]-> swift 'International transfers' {
    technology 'MQ, MT103/MT202'
  }

  // --- Risk ---
  bank.support.risk.aml -[sync]-> bank.business.products.core_banking 'Customer data lookup' {
    technology 'REST/JSON'
  }
  bank.support.risk.anti_fraud -[async]-> bank.business.payments.payment_hub 'Fraud alerts' {
    technology 'Kafka, Avro'
  }
  bank.support.risk.aml -[sync]-> cbr 'SAR reports, sanctions lists' {
    technology 'SOAP/XML, SFTP'
  }

  // --- Analytics ---
  bank.tech.analytics.dwh -[reads]-> bank.business.products.core_banking 'Replicated data' {
    technology 'CDC, Debezium'
  }
  bank.tech.analytics.reporting_engine -[reads]-> bank.tech.analytics.dwh 'Analytical queries' {
    technology 'SQL/JDBC'
  }
  bank.tech.analytics.reporting_engine -[sync]-> cbr 'Regulatory reports' {
    technology 'SFTP'
  }

  // --- Auth ---
  bank.tech.platform.iam -[reads]-> bank.business.products.core_banking 'User directory sync' {
    technology 'LDAP'
  }

  // --- Notifications from core ---
  bank.business.products.core_banking -[async]-> bank.support.notifications.notification_center 'Account events' {
    technology 'Kafka, Avro'
  }
}
