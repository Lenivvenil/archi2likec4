model {
  extend bank.payments {
    payment_hub = system 'Payment Hub' {
      #critical
      #pci_dss
      description 'Payment orchestration: P2P, P2B, SWIFT, card'
      technology 'Java 17, Spring Boot, Kafka'
    }
    card_processing = system 'Card Processing' {
      #critical
      #pci_dss
      #pii
      description 'Card issuing, acquiring, authorization, settlement'
      technology 'Java 17'
    }
  }
}
