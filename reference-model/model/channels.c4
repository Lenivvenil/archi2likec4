model {
  extend bank.channels {
    mobile_bank = mobileApp 'Mobile Bank' {
      #pii
      description 'iOS/Android mobile banking application'
      technology 'Swift, Kotlin'
    }
    internet_bank = webapp 'Internet Bank' {
      #pii
      description 'Web banking portal for retail and back-office'
      technology 'TypeScript, React'
    }
  }
}
