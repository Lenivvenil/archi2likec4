// ── IAM / SSO — Deployment ───────────────────────────────────
deployment {
  extend prod.dc1.app.k8s.ns_platform {
    instanceOf bank.tech.platform.iam
  }
}

views {
  deployment view iam_deployment {
    title 'IAM / SSO — Production Deployment'
    include prod.dc1.app.k8s.ns_platform.*
    autoLayout TopBottom
  }
}
