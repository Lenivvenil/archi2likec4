// ── Anti-Fraud — Deployment ──────────────────────────────────
deployment {
  extend prod.dc1.app.k8s.ns_risk {
    instanceOf bank.support.risk.anti_fraud
  }
}

views {
  deployment view anti_fraud_deployment {
    title 'Anti-Fraud — Production Deployment'
    include prod.dc1.app.k8s.ns_risk.*
    autoLayout TopBottom
  }
}
